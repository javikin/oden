{
  "name": "oden-forge",
  "version": "3.0.0",
  "description": "Living Quality Gates for Claude Code - Enforce 80%+ test coverage, detect patterns, and prevent bad code from reaching production with automatic quality enforcement",
  "keywords": [
    "claude-code",
    "quality-gates",
    "testing",
    "coverage",
    "code-quality",
    "development-toolkit",
    "skills",
    "mcp"
  ],
  "homepage": "https://javikin.github.io/oden-forge",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/javikin/oden-forge.git"
  },
  "bugs": {
    "url": "https://github.com/javikin/oden-forge/issues"
  },
  "author": {
    "name": "javikin",
    "url": "https://github.com/javikin"
  },
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "bin": {
    "oden-forge": "bin/oden-forge.js",
    "oden-install": "bin/install.js"
  },
  "files": [
    "bin/",
    ".claude/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node bin/post-install.js",
    "preuninstall": "node bin/pre-uninstall.js",
    "test": "echo \"No tests yet\" && exit 0",
    "docs:dev": "cd docs && python3 -m http.server 8000",
    "docs:deploy": "echo \"Docs deployed via GitHub Pages automatically\""
  },
  "preferGlobal": true,
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.4.1",
    "inquirer": "^8.2.5",
    "fs-extra": "^11.1.1",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "gh-pages": "^6.1.0"
  },
  "claude-code": {
    "type": "skills-package",
    "install-location": "~/.claude/",
    "commands": [
      "oden:init",
      "oden:architect",
      "oden:prd",
      "oden:epic",
      "oden:tasks",
      "oden:work",
      "oden:sync",
      "oden:test",
      "oden:adr",
      "oden:context",
      "oden:debug",
      "oden:mcp",
      "oden:help"
    ],
    "version-check": true,
    "auto-migrate": true
  }
}